# Supabase (Local or Hosted)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# GitHub Actions dispatch (production pipeline execution + static export).
# The pipeline sleeps through free-tier LLM rate limits, so it must run on
# an Actions runner — a Vercel function is killed at 300s. Locally these
# can stay unset: `pnpm dev` runs the pipeline inline instead.
# GITHUB_PAT: fine-grained personal access token, Actions read+write on the repo.
GITHUB_REPO=Shreyash0712/Fineprinted
GITHUB_PAT=your_github_pat
# GITHUB_BRANCH=main

# AI & Embeddings
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# Rate limits the pipeline throttles itself to (defaults = provider free
# tiers). Raise these after upgrading your Groq/Gemini plan.
# GROQ_REASONING_RPM=30
# GROQ_REASONING_TPM=8000
# GROQ_BULK_RPM=30
# GROQ_BULK_TPM=30000
# GEMINI_EMBED_RPM=60
# GEMINI_EMBED_TPM=200000

# Admin panel
ADMIN_PASSWORD=choose_a_strong_password
# Optional: separate secret for signing session cookies (falls back to ADMIN_PASSWORD)
ADMIN_SESSION_SECRET=any_long_random_string
